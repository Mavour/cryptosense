# =============================================
# CRYPTOSENSE BOT — Environment Configuration
# =============================================

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Alternatif model gratis OpenRouter:
# google/gemini-flash-1.5
# mistralai/mistral-7b-instruct:free
# deepseek/deepseek-chat:free

# CryptoCompare News API (opsional tapi direkomendasikan)
# Daftar gratis di: https://www.cryptocompare.com/cryptopian/api-keys
# Tanpa key: tetap jalan, limit 30 req/min
# Dengan key: limit jauh lebih longgar
CRYPTOCOMPARE_API_KEY=

# CoinGecko (tanpa key pun jalan, tapi rate limit lebih longgar dengan key)
COINGECKO_API_KEY=

# Bot Config
ADMIN_CHAT_ID=your_telegram_chat_id
SCAN_INTERVAL_HOURS=4
MAX_WATCHLIST_PER_USER=10
CACHE_TTL_MINUTES=5
